---
---
<header class="sticky top-0 z-50" style="
  background: oklch(0.970 0.012 78 / 0.92);
  backdrop-filter: blur(14px) saturate(1.2);
  border-bottom: 1px solid oklch(0.58 0.090 155 / 0.18);
">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between gap-6">

    <!-- Logo / Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group" style="text-decoration: none;">
      <!-- Clearway leaf mark -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
        <path d="M6 26 C6 26, 10 8, 26 6 C26 6, 22 24, 6 26Z"
          fill="oklch(0.46 0.095 155)"
          opacity="0.9"
        />
        <path d="M6 26 L18 14"
          stroke="oklch(0.68 0.145 55)"
          stroke-width="1.5"
          stroke-linecap="round"
          fill="none"
        />
      </svg>
      <span
        class="font-display font-semibold tracking-tight"
        style="font-size: 1.25rem; color: oklch(0.28 0.022 78); letter-spacing: -0.01em;"
      >
        Clearway
      </span>
    </a>

    <!-- Nav links — desktop -->
    <div class="hidden md:flex items-center gap-7">
      <a
        href="#topics"
        class="font-display text-sm font-medium transition-colors duration-150"
        style="color: oklch(0.50 0.025 80); letter-spacing: 0.01em;"
        onmouseover="this.style.color='oklch(0.28 0.022 78)'"
        onmouseout="this.style.color='oklch(0.50 0.025 80)'"
      >
        Topics
      </a>
      <a
        href="/blog"
        class="font-display text-sm font-medium transition-colors duration-150"
        style="color: oklch(0.50 0.025 80); letter-spacing: 0.01em;"
        onmouseover="this.style.color='oklch(0.28 0.022 78)'"
        onmouseout="this.style.color='oklch(0.50 0.025 80)'"
      >
        Articles
      </a>
      <a
        href="#newsletter"
        class="font-display text-sm font-semibold transition-colors duration-150"
        style="color: oklch(0.50 0.025 80); letter-spacing: 0.01em;"
        onmouseover="this.style.color='oklch(0.28 0.022 78)'"
        onmouseout="this.style.color='oklch(0.50 0.025 80)'"
      >
        Newsletter
      </a>
    </div>

    <!-- CTA -->
    <a
      href="#newsletter"
      class="inline-flex items-center gap-1.5 font-display text-sm font-semibold px-5 py-2.5 rounded-sm transition-all duration-150"
      style="background: oklch(0.46 0.095 155); color: oklch(0.97 0.008 80); letter-spacing: 0.02em;"
      onmouseover="this.style.background='oklch(0.38 0.085 155)'"
      onmouseout="this.style.background='oklch(0.46 0.095 155)'"
    >
      Free weekly guide
    </a>

  </nav>
</header>
