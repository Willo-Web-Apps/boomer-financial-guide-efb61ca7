---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Clearway — Retirement Finance in Plain English",
  description = "Clearway is the trusted retirement finance guide for baby boomers. Plain-English answers on Social Security, Medicare, RMDs, and withdrawal strategies — no jargon, no sales pitch."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#2C5F4A" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Clearway",
      "description": "Retirement finance, finally in plain English — Social Security, Medicare, RMDs, and withdrawal strategies for baby boomers.",
      "url": "https://clearway.onrender.com",
      "audience": {
        "@type": "Audience",
        "audienceType": "Baby boomers, ages 60–72, planning or entering retirement"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.970 0.012 78); color: oklch(0.28 0.020 80);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
